temp/

# Atlas: GeoJSON is an intermediate generated by tippecanoe; only the
# .pmtiles archive ships. Frontend reads pmtiles directly.
stats/nepi_static/*.geojson
docs/*.geojson

# Atlas: National OA pmtiles is ~260 MB — too large for GitHub (100 MB
# per-file limit). Hosted externally on Cloudflare R2 (or similar) and
# referenced by URL in summary.json. Set ATLAS_OA_TILES_URL_BASE before
# running export_atlas_data.py to embed the absolute R2 URL.
stats/nepi_static/*_oa.pmtiles
docs/*_oa.pmtiles

